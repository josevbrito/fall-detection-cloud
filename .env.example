# .env.example — SERVIDOR. Copie para .env e ajuste:
#   cp .env.example .env

# Credenciais do PostgreSQL do ThingsBoard.
# IMPORTANTE: o cliente (load test) usa estas mesmas credenciais no .env dele.
POSTGRES_USER=thingsboard
POSTGRES_PASSWORD=thingsboard2026

# Senha do admin do Grafana (só usada com --profile monitoring).
GRAFANA_ADMIN_PASSWORD=admin

# --- Somente para o modo público (docker-compose.public.yml com Caddy/TLS) ---
# Domínio que aponta (A record) para o IP público da VM. Ignorado no modo LAN.
TB_DOMAIN=iot.exemplo.com
