# .env.example — SERVIDOR. Copie para .env e ajuste:
#   cp .env.example .env

# Credenciais do PostgreSQL do ThingsBoard.
# IMPORTANTE: o cliente (load test) usa estas mesmas credenciais no .env dele.
POSTGRES_USER=thingsboard
POSTGRES_PASSWORD=thingsboard2026

# Senha do admin do Grafana (só usada com --profile monitoring).
GRAFANA_ADMIN_PASSWORD=admin

# --- Somente para o modo público (docker-compose.public.yml com Caddy/TLS) ---
# Domínio-base da instância. O Caddy monta os subdomínios em cima dele:
#   fall-detection.<IOT_DOMAIN>, dashboard.<IOT_DOMAIN>, grafana.<IOT_DOMAIN>,
#   push.<IOT_DOMAIN>.
# Use um valor DIFERENTE por instância (os wildcards já apontam pra cada EC2):
#   - Instância 1 (principal):  IOT_DOMAIN=iot.josevbrito.com
#   - Instância 2 (backup):     IOT_DOMAIN=1.iot.josevbrito.com
IOT_DOMAIN=iot.josevbrito.com
